/* v1.0 */
:root { --bg:#0b0e13; --fg:#e8eef6; --muted:#9bb2ca; --card:#121824; --accent:#4da3ff; }
*{box-sizing:border-box} body{margin:0;font-family:system-ui,Segoe UI,Arial;background:var(--bg);color:var(--fg)}
a{color:var(--accent);text-decoration:none} a:hover{text-decoration:underline}
.topbar{display:flex;justify-content:space-between;align-items:center;padding:12px 18px;background:#0e1420;border-bottom:1px solid #1e2a3a}
.brand{font-weight:700}
.container{max-width:1100px;margin:24px auto;padding:0 16px}
.nav a{margin-right:12px}
.auth-card{max-width:420px;margin:60px auto;padding:24px;background:var(--card);border-radius:12px}
.auth-card h1{margin-top:0}
.auth-card form label{display:block;margin:12px 0}
input,button{width:100%;padding:10px 12px;border-radius:8px;border:1px solid #1e2a3a;background:#0f1522;color:var(--fg)}
button{cursor:pointer;background:var(--accent);color:#0b0e13;border:none;font-weight:600}
.alert{padding:10px 12px;border-radius:8px;margin:12px 0}
.alert.error{background:#3a0d16} .alert.success{background:#0e2a14}
.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:14px 0 22px}
.card{background:var(--card);padding:16px;border-radius:12px;border:1px solid #1e2a3a}
.kpi-label{font-size:12px;color:var(--muted)} .kpi-value{font-size:28px;font-weight:700;margin-top:6px}
.table{width:100%;border-collapse:collapse;background:var(--card);border-radius:12px;overflow:hidden}
.table th,.table td{padding:10px;border-bottom:1px solid #1e2a3a;text-align:left}
.footer{padding:16px;color:var(--muted);text-align:center;border-top:1px solid #1e2a3a;margin-top:24px}
@media (max-width:900px){.grid{grid-template-columns:repeat(2,1fr)}}
@media (max-width:520px){.grid{grid-template-columns:1fr}}
